# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# Original API Provider Keys (Middleman Configuration)
# These are the credentials for the actual API providers you're reselling
ORIGINAL_TEXT_ANALYSIS_API_URL=https://api.original-provider.com/v1/analyze
ORIGINAL_TEXT_ANALYSIS_API_KEY=original-api-key

ORIGINAL_IMAGE_RECOGNITION_API_URL=https://api.vision-provider.com/v1/detect
ORIGINAL_IMAGE_RECOGNITION_API_KEY=original-api-key

ORIGINAL_DATA_ENRICHMENT_API_URL=https://api.data-provider.com/v1/enrich
ORIGINAL_DATA_ENRICHMENT_API_KEY=original-api-key
